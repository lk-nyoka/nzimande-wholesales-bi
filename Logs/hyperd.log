{"ts":"2026-06-16T02:18:35.732325","pid":23380,"tid":"660c|mux t5","sev":"info","req":"6","sess":"kC__aGGXR4iypnwnu7CaUw","ctx":{"workload":{"name":"tableau-interactive"},"tenant-id":"-","user-agent":"{\"app\": \"Tableau\", \"edition\": \"pro\", \"version\": \"20261.26.0410.0924\"}","client":{"req":"-","site":"-","user":"-","host":"LAPTOP-03DT903K"}},"k":"query-begin","v":{"spooling":false,"query-settings-active":false,"query-hash":"639d.7d599d119401.b84a3e","query":"SELECT c.contype, c.conname, a.attname, a.attnotnull, tns.relname, unnest_conkey, conkey_string, tns.nspname as ref_ns\n  FROM pg_catalog.pg_class cl\n  JOIN ( SELECT c.contype, unnest(c.conkey) AS unnest_conkey,\n                c.conname, c.confrelid, array_to_string(c.conkey, ',', '*') as conkey_string,\n                c.conrelid\n          FROM pg_catalog.pg_constraint c) c\n   ON c.conrelid = cl.oid\n  JOIN pg_catalog.pg_attribute a\n   ON  c.unnest_conkey = a.attnum\n   AND a.attrelid      = cl.oid\n  LEFT JOIN (\n    SELECT t.oid, t.relname, ns.nspname\n    FROM pg_catalog.pg_class t\n    JOIN pg_catalog.pg_namespace ns\n      ON ns.oid = t.relnamespace\n    WHERE t.relkind IN('r','v','f')\n     AND ns.nspname not like 'pg_catalog') tns\n  ON c.confrelid = tns.oid\n WHERE NOT a.attisdropped\n   AND cl.relname = 'Extract'\n   AND cl.relnamespace = 10004"}}
