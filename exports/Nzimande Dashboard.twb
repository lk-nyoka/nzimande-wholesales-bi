      <column caption='Gross Revenue' datatype='real' name='[Calculation_0501390278750208]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Total Spent])' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_0501390278897665]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Total Spent])' />
      </column>
      <column caption='Total Units' datatype='real' name='[Calculation_0501390279004162]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Quantity])' />
      </column>
      <column caption='Discount Rate' datatype='real' default-format='p0.00%' name='[Calculation_0501390279634948]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Discount Applied] = &quot;True&quot; THEN 1 ELSE 0 END) / COUNT([Transaction ID])' />
      </column>
      <column caption='AOV by Location' datatype='real' name='[Calculation_0501390324658181]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Total Spent]) / COUNT([Transaction ID])' />
      </column>
